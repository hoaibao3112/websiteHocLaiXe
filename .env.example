# Environment Variables — Website Trường Lái Xe Chiến Thắng
# Copy file này thành .env.local và điền values từ Supabase dashboard

# ============================================================
# SUPABASE (bắt buộc — lấy từ Project Settings > API)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# ⚠️ KHÔNG prefix NEXT_PUBLIC_ — chỉ dùng server-side
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ============================================================
# ISR REVALIDATION SECRET
# ============================================================
# Tạo random string: openssl rand -base64 32
REVALIDATE_SECRET=change_me_random_secret_string

# ============================================================
# GOOGLE ANALYTICS (GA4)
# ============================================================
NEXT_PUBLIC_GA_ID=G-XXXXXX

# ============================================================
# GMAIL SMTP CONFIGURATION (Cách 2: Gửi từ Gmail phụ về Gmail chính)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=gmail_phu_de_gui@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx # Mật khẩu ứng dụng 16 ký tự của Gmail phụ
RECEIVER_EMAIL=gmail_chinh_de_nhan@gmail.com # Gmail cá nhân chính của bạn để nhận thông báo


